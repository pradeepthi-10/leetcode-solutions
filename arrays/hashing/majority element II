class Solution {
 public List<Integer> majorityElement(int[] nums) {
        HashMap<Integer,Integer> map = new HashMap<>();
        List<Integer>ans=new ArrayList<>();
        int n = nums.length;
        for(int i =0;i<nums.length;i++)
        {
            int count=0;
            if(map.containsKey(nums[i])){
             count= map.get(nums[i]);
             count=count+1;
            }
            else{
                count++;
            }
            map.put(nums[i],count);
            
              if(count>n/3 && !ans.contains(nums[i])){
                ans.add(nums[i]);
             }
            
        
        }return ans;

    }
}
// here we used hashmap to store the count of each element in the array. We iterate through the array and check if the current element is already present in 
// the hashmap. If it is, we increment the count of that element in the hashmap. If it is not present, we add it to the hashmap with a count of 1.
// 