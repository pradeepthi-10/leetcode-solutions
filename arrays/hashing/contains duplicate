class Solution {
    public boolean containsDuplicate(int[] nums) {
        HashSet<Integer>Set=new HashSet<>();
        for(int i=0;i<nums.length;i++)
        {
            
            if(Set.contains(nums[i])){
                return true;
            }
            Set.add(nums[i]);
        }return false;
    }
}
// here we used hashset because it does not allow duplicate values. We iterate through the array
// and check if the current element is already present in the hashset. If it is, we return true 
// else false intailly we check then add the element to the hashset. This way we can check for duplicates in O(n) time complexity and O(n) space complexity.