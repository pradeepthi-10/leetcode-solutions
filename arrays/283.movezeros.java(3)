class Solution {
    public void moveZeroes(int[] nums) {
        int p1=0;
        int p2=0;
        int temp;
        for(p1=0;p1<nums.length;p1++)
        {
            if(nums[p1]!=0)
            {
                temp=nums[p1];
                nums[p1]=nums[p2];
                nums[p2]=temp;
                p2++;
          }
        }
        for(int i=0;i<nums.length;i++)
        {
            System.out.print(nums[i]+" ");
        }
            

        }
    }