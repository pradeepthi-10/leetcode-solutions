class Solution {
    public int[] twoSum(int[] numbers, int target) {
        int p1=0;
        int p2=numbers.length-1;
        for(int i=0;i<numbers.length;i++)
        {
            if(numbers[p1]+numbers[p2]>target)
            {
                p2--;
            }
            else if(numbers[p1]+numbers[p2]<target)
            {
                p1++;
            }
            else{
                return new int[]{p1+1,p2+1};
            }
        }
    return new int[]{p1+1,p2+1};
}
}