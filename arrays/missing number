class Solution {
    public int missingNumber(int[] nums) {
        int n=nums.length;
        int actualsum = (n*(n+1))/2;
        int sum=0;
        for(int i =0;i<nums.length;i++)
        {
            sum = sum+nums[i];
        }
        int resu = actualsum-sum;
        return resu;

    }
}
// in this problem we only have one missing element hence we first sum all the element using for loop 
// we have formula to calculate sum of n numbers that is n*(n+1)/2. We calculate the actual sum of n numbers 
// now we just subtract the sum from the actual sum to get the miss This